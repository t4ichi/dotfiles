# git identity テンプレート（全 identity 共通フォーマット）。
# 使い方: この雛形を identity-<name>.gitconfig にコピーして name/email を書き換える。
#   例) cp identity.gitconfig.example identity-work.gitconfig
#       cp identity.gitconfig.example identity-personal.gitconfig
# 切り替え: git-identity <name>
# 個人用は GitHub の noreply メール（設定 > Emails）を使うと個人メールを晒さずに済む。
[user]
	name = Your Name
	email = you@example.com
